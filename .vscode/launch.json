{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: FastAPI (mock mode)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "APP_MODE": "mock",
        "PYTHONPATH": "${workspaceFolder}/src/api",
        "PYTHONUNBUFFERED": "1"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Agent: Launch and Open Inspector",
      "type": "debugpy",
      "request": "launch",
      "module": "agent_dev_cli",
      "args": ["--verbose", "run", "server"],
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "preLaunchTask": "Open Agent Inspector"
    },
    {
      "name": "Agent: Attach",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false
    }
  ]
}
